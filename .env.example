# GTS Media channel ID (no YouTube API key needed anymore - the server
# only uses YouTube's public no-key endpoints now)
YOUTUBE_CHANNEL_ID=UCEB4RPREmkCSQpneVpFbnbQ

# Password for the /admin page where you set the next scheduled
# broadcast (replaces YouTube's "upcoming broadcasts" API). Visit
# https://your-server-url/admin?secret=THIS_VALUE
ADMIN_SECRET=change-me-to-something-random

# How often to poll YouTube, in seconds (60 is a safe default)
POLL_INTERVAL_SECONDS=60

# Port the server listens on (most hosts inject this automatically)
PORT=3000

# Simple shared secret so randoms on the internet can't spam your
# /register-token endpoint. The app must send this same value.
REGISTER_SHARED_SECRET=change-me-to-something-random
