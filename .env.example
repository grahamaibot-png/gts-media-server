# YouTube Data API v3 key (same one used in the app, or a separate server key)
YOUTUBE_API_KEY=your_youtube_api_key_here

# GTS Media channel ID
YOUTUBE_CHANNEL_ID=UCEB4RPREmkCSQpneVpFbnbQ

# How often to poll YouTube, in seconds (60 is a safe default and keeps
# well within the free daily API quota)
POLL_INTERVAL_SECONDS=60

# Port the server listens on (most hosts inject this automatically)
PORT=3000

# Simple shared secret so randoms on the internet can't spam your
# /register-token endpoint. The app must send this same value.
REGISTER_SHARED_SECRET=change-me-to-something-random
